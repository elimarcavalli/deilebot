# =============================================================================
# .gitignore -- deilebot
# Stack: Python (asyncio + SQLite + provedores Discord/Telegram/WhatsApp)
# =============================================================================

# -----------------------------------------------------------------------------
# Python -- bytecode, caches e artefatos do interpretador
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# -----------------------------------------------------------------------------
# Distribuicao / packaging
# -----------------------------------------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Ambientes virtuais
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Testes / cobertura / linters
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
.cache
nosetests.xml
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# Bancos de dados locais e dados runtime do bot
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
deile_tasks.db
data/
cache/

# -----------------------------------------------------------------------------
# Logs e arquivos de saida temporarios
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
RUNS/
PLANS/
PATCHES/

# -----------------------------------------------------------------------------
# Segredos / credenciais (NUNCA commitar)
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
secrets/
credentials/
*.tokens
discord_token.txt
telegram_token.txt

# -----------------------------------------------------------------------------
# IDEs / editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Sistema operacional
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Ferramentas de build / containers (opcional)
# -----------------------------------------------------------------------------
*.pid
*.seed
*.tar
*.tar.gz
*.zip
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Arquivos temporarios do projeto
# -----------------------------------------------------------------------------
tmp/
temp/
.tmp/
scratch/
_testing.py
!deilebot/_testing.py
