# .env — segredos do deilebot + do agente DEILE. Carregado por python-dotenv.
#
# Copie este arquivo para `.env` (na raiz do repositório `deile`, de onde o
# bot é executado) e preencha os valores. NUNCA faça commit do `.env` real.
#
# Atalho: `python -m deilebot setup` gera este arquivo interativamente,
# validando o token do Discord ao vivo. Use este template apenas se
# preferir a configuração manual.

# --- Discord (obrigatório) ---------------------------------------------------
# Token do bot: Discord Developer Portal -> sua aplicação -> aba "Bot" ->
# "Reset Token". Lembre de ligar os Privileged Intents (MESSAGE CONTENT e
# SERVER MEMBERS) na mesma página.
DEILE_BOT_DISCORD_TOKEN=

# --- LLM (obrigatório: ao menos UMA chave) -----------------------------------
# O agente DEILE embarcado precisa de uma chave de LLM para responder.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# --- Control plane HTTP (a "flecha reversa" agente -> bot) -------------------
# Token Bearer da API HTTP de control plane. Gere um valor aleatório forte:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DEILE_BOT_CONTROL_PLANE_AUTH_TOKEN=
# O mesmo valor, sob o nome que o `infra/k8s/deploy.py` lê para criar o
# Secret do Kubernetes. Mantenha os dois iguais.
DEILE_BOT_AUTH_TOKEN=

# --- Forge (opcionais) -------------------------------------------------------
# GitHub: token de leitura/clone — usado por `deploy.py clone` (modo container).
# Para /git login PAT, cole o token diretamente no modal do Discord.
GITHUB_TOKEN=

# GitLab: token pessoal (glpat-…) ou service account (glsoat-…).
# Usado pelo /git login e pelo wizard (_step_forge).
GITLAB_TOKEN=
# Alias aceito também: GL_TOKEN=

# Bearer próprio do deile-worker (modo container). Se vazio, o deploy.py gera um.
DEILE_WORKER_BEARER_TOKEN=
